{% extends 'admin/base_with_header.html.twig' %}

{% block content %}
    <h2>Interview {{ event.title }}{% if interview.id is defined %} #{{ interview.id }}{% endif %}</h2>

    {% form_theme form 'form_theme_admin.html.twig' %}

    {{ form_start(form) }}
    {{ form_errors(form) }}

    <div class="ui segment">
        <h3 class="ui header">Speaker(s)</h3>
        <div class="ui clearing divider"></div>
        <div class="ui form">
            {{ form_row(form.speakers) }}
        </div>
    </div>

    <div class="ui segment">
        <h3 class="ui header">Publication</h3>
        <div class="ui clearing divider"></div>
        <div class="ui form">
            {{ form_row(form.datePublication) }}
        </div>
    </div>

    <div class="ui segment">
        <h3 class="ui header">Questions</h3>

        {% set index = form.questions|length %}
        <div class="ui form interview_question_container" data-index="{{ index }}"
             data-prototype="{{ include('admin/event/interview/_prototype.html.twig', {form: form})|e('html_attr') }}">
            {% for questionForm in form.questions %}
                <div id="interview_question_{{ loop.index0 }}" class="interview_question_item">
                    <div class="ui clearing divider"></div>
                    <div class="inline fields ui grid">
                        <div class="three wide column"></div>
                        <div class="field nine wide column">Question {{ loop.index }}</div>
                        <div class="four wide column action_container"></div>
                    </div>
                    {{ form_row(questionForm.question) }}
                    {{ form_row(questionForm.reponse) }}
                </div>
            {% endfor %}
        </div>
        <div class="inline grid ui">
            <div class="column twelve wide"></div>
            <div class="column four wide">
                <a href="javascript:void(0);" class="ui primary button add_item_link"
                   data-collection-holder-class="interview_question_container">
                    Ajouter une question
                </a>
            </div>
        </div>
    </div>

    <div class="ui segment">
        <input type="submit" value="Enregistrer" class="ui primary button">
    </div>

    {{ form_end(form) }}

    {% include 'admin/event/interview/_javascript.html.twig' %}
{% endblock %}
